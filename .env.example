# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-random-32-char-string"

# iron-session encryption secret — must be at least 32 characters
SESSION_SECRET="replace-with-a-different-random-32-char-string"

# ─── App User ─────────────────────────────────────────────────────────────────
# Single-user personal setup — set your login credentials here
# Password will be bcrypt-hashed on first run via the setup script
APP_USERNAME="admin"
# Run: node scripts/hash-password.mjs yourpassword
# Then paste the hash below
APP_PASSWORD_HASH="\$2b\$12\$replace-with-bcrypt-hash"

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOADS_DIR="./uploads"
MAX_FILE_SIZE_MB="10"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="My Expenses"
NODE_ENV="development"
